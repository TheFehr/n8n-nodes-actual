{
  "name": "n8n-nodes-actual",
  "version": "26.7.0",
  "description": "Interact with your Actual Budget instance",
  "license": "MIT",
  "homepage": "",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Philipp Fehr",
    "email": "philipp@thefehr.me"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheFehr/n8n-nodes-actual.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:pipeline": "bash scripts/full-test.sh",
    "version:check": "node scripts/update-versions.mjs --check",
    "version:update": "node scripts/update-versions.mjs",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist",
    "vendor"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/ActualBudgetApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ActualBudget/ActualBudget.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/node": "^25.5.2",
    "eslint": "9.39.2",
    "prettier": "3.8.2",
    "release-it": "^20.0.0",
    "typescript": "5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "^2.16.0"
  },
  "dependencies": {
    "@actual-app/api": "26.7.0",
    "detect-libc": "^2.1.2"
  }
}
